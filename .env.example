# Default Neo4j connection
NEO4J_URI=neo4j+ssc://xxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Optional: separate export source
# NEO4J_EXPORT_URI=neo4j+ssc://source.databases.neo4j.io
# NEO4J_EXPORT_USERNAME=neo4j
# NEO4J_EXPORT_PASSWORD=
# NEO4J_EXPORT_DATABASE=neo4j

# Optional: separate import target
# NEO4J_IMPORT_URI=neo4j+ssc://target.databases.neo4j.io
# NEO4J_IMPORT_USERNAME=neo4j
# NEO4J_IMPORT_PASSWORD=
# NEO4J_IMPORT_DATABASE=neo4j
